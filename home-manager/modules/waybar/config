{
    "height": 30,
    "layer": "top", 
    "margin-top": 6,
    "margin-left": 10,
    "margin-bottom": 0,
    "margin-right": 10,
    "spacing": 5, 
    "modules-left": ["custom/launcher", "battery", "cpu", "memory", "hyprland/workspaces", "custom/weather"],
    "modules-center": ["custom/spotify", "hyprland/window"],
    "modules-right": ["tray",  "custom/network", "pulseaudio", "clock", "custom/power-menu"],
    "hyprland/workspaces": {
      "format": "{id}",
      "on-click": "activate",
      "format-icons": {
        "1": "яДС",
        "2": "яДС",
        "3": "яДС",
        "4": "яДС",
        "5": "яДС",
        "urgent": "яБк",
        "active": "яДС",
        "default": "яДС"
      }
    },
    "hyprland/window": {
        "format": "{}"
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "format": "<span color='#bf616a'>яБ│ </span>{:%d.%m - %H:%M}",
        "format-alt": "<span color='#bf616a'>яАЧ </span>{:%I:%M %p}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "cpu": {
      "interval": 10,
      "format": "CPU: {}%",
      "max-length": 10,
      "on-click": ""
    },
    "memory": {
        "interval": 30,
        "format": "яШк {}%",
        "format-alt":"яС▓ {used:0.1f}G",
        "max-length": 10
    },
    "backlight": {
        "device": "DP-1",
        "format": "{icon} {percent}%",
        "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"],
        "on-click": ""
    },
    "network": {
        "format-wifi": "{signalStrength}%",
        "format-ethernet": "",
        "on-click": "bash ~/.config/waybar/scripts/rofi-wifi-menu.sh",
        "format-disconnected": ""
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "яАе яКФ {volume}%",
        "format-bluetooth-muted": "яЪй яКФ",
        "format-muted": "яЪй",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "pavucontrol"
    },

    "custom/power-menu": {
        "format": " <span color='#6a92d7'>тП╗ </span>",
        "on-click": "bash /home/simonkdev/nixsys/home-manager/modules/waybar/power-menu.sh"
    },
    "custom/launcher": {
        "format": " <span color='#6a92d7'>яЮЯ </span>",
        "on-click": "wofi --show drun"
    },

    "custom/network": {
        "format": "{icon}",
        "on-click": "networkmanager_dmenu"
    }
}
