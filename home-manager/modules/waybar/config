{
    "height": 30,
    "layer": "top", 
    "margin-top": 6,
    "margin-left": 10,
    "margin-bottom": 0,
    "margin-right": 10,
    "spacing": 5, 
    "modules-left": ["custom/launcher", "battery", "cpu", "memory", "hyprland/workspaces", "custom/weather"],
    "modules-center": ["custom/spotify", "hyprland/window"],
    "modules-right": ["tray", "pulseaudio", "network", "clock", "custom/power-menu"],
    "hyprland/workspaces": {
      "format": "{id}",
      "on-click": "activate",
      "format-icons": {
        "1": "п„‘",
        "2": "п„‘",
        "3": "п„‘",
        "4": "п„‘",
        "5": "п„‘",
        "urgent": "пҒӘ",
        "active": "п„‘",
        "default": "п„‘"
      }
    },
    "hyprland/window": {
        "format": "{}"
